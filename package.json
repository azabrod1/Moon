{
  "name": "moon",
  "version": "1.0.0",
  "description": "Flyable solar-system planetarium: real ephemerides, eclipses, and surface observatories",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen:stars": "node gen-stars.mjs",
    "gen:moons": "node gen-moons.mjs",
    "gen:constellations": "node gen-constellations.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "three": "^0.183.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "vitest": "^4.1.8"
  }
}
